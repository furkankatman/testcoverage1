<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <!-- Include your main project -->
          <Include>[*]*</Include>

          <!-- Exclude Program.cs only -->
          <ExcludeByFile>
		  **/Program.cs
			**/Startup.cs
			**/Migrations/*
			**/*.g.cs
			**/*.designer.cs
	      </ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
